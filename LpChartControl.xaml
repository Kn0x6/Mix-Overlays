<UserControl x:Class="MixOverlays.Views.LpChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Grid>
        <Canvas x:Name="ChartCanvas" Background="Transparent"
                SizeChanged="ChartCanvas_SizeChanged"
                MouseMove="ChartCanvas_MouseMove"
                MouseLeave="ChartCanvas_MouseLeave"/>

        <!-- Tooltip flottant — petit, compact, positionné par code -->
        <Border x:Name="TooltipBorder"
                Background="#EE0D1117"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                CornerRadius="5"
                Padding="6,4"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Panel.ZIndex="10">
            <StackPanel>
                <TextBlock x:Name="TipDate"  Foreground="#6B7280" FontSize="8"/>
                <TextBlock x:Name="TipRank"  Foreground="#59A6EF" FontSize="10" FontWeight="Bold" Margin="0,1,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
