<UserControl x:Class="MixOverlays.Views.PlayerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MixOverlays.Views"
             xmlns:views="clr-namespace:MixOverlays.Views"
             xmlns:conv="clr-namespace:MixOverlays.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter             x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter      x:Key="InvBoolVis"/>
        <conv:WinLossBrushConverter                 x:Key="WinLossBrush"/>
        <conv:WinLossTextConverter                  x:Key="WinLossText"/>
        <conv:RankTierBrushConverter                x:Key="RankBrush"/>
        <conv:KdaBrushConverter                     x:Key="KdaBrush"/>
        <conv:WinRateBrushConverter                 x:Key="WinRateBrush"/>
        <conv:DoubleFormatConverter                 x:Key="DblFmt"/>
        <conv:PercentFormatConverter                x:Key="PctFmt"/>
        <conv:MasteryPointsConverter                x:Key="MasteryPts"/>
        <conv:GameDurationConverter                 x:Key="GameDuration"/>
        <conv:TimeAgoConverter                      x:Key="TimeAgo"/>
        <conv:UrlToImageSourceConverter             x:Key="UrlToImg"/>
        <conv:UrlToImageSourceWithFallbackConverter x:Key="UrlToImgWithFallback"/>
        <conv:ChampionNameToImageConverter          x:Key="ChampToImg"/>
        <conv:ChampionIdToImageConverter            x:Key="ChampIdToImg"/>
        <conv:SummonerSpellIdToImageConverter       x:Key="SpellToImg"/>
        <conv:RuneIdToImageConverter                x:Key="RuneToImg"/>
        <conv:ChampionNameToSplashConverter         x:Key="ChampSplash"/>
        <conv:HexStringToBrushConverter             x:Key="HexBrush"/>
    </UserControl.Resources>

    <!-- ROOT — pas de ScrollViewer ici : la MainWindow gère le défilement -->
    <Border Background="#12151E" BorderBrush="#1E2435" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Banner -->
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Separator -->
                <RowDefinition Height="Auto"/>  <!-- Body 2-col -->
            </Grid.RowDefinitions>

            <!-- Loading banner -->
            <Border Grid.Row="0" Background="#1A8B5CF6" CornerRadius="12,12,0,0" Padding="10,6"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                <TextBlock Text="⏳  Chargement…" Foreground="#8B5CF6" FontSize="11" HorizontalAlignment="Center"/>
            </Border>

            <!-- Error banner -->
            <Border Grid.Row="0" Background="#1AF85149" CornerRadius="12,12,0,0" Padding="10,6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F85149" FontSize="10" TextTrimming="CharacterEllipsis"/>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- HEADER                                                         -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="1" ClipToBounds="True" Height="150">
                <Grid>
                    <!-- ── Splash art en fond ── -->
                    <Image Source="{Binding TopChampionName, Converter={StaticResource ChampSplash}}"
                           Stretch="UniformToFill"
                           Opacity="0.30"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"/>

                    <!-- ── Dégradé gauche plus fort ── -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F012151E" Offset="0.0"/>
                                <GradientStop Color="#CC12151E" Offset="0.35"/>
                                <GradientStop Color="#6612151E" Offset="0.65"/>
                                <GradientStop Color="#1012151E" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- ── Dégradé bas (fondu vers le contenu dessous) ── -->
                    <Border VerticalAlignment="Bottom" Height="50">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#0012151E" Offset="0"/>
                                <GradientStop Color="#FF12151E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- ── Contenu original (une seule fois, par-dessus le splash) ── -->
                    <Grid Margin="16,14,16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <!-- Solo/Duo badge -->
                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,0,0,4"
                                    Background="#1A3B82F6" BorderBrush="#303B82F6" BorderThickness="1">
                                <TextBlock Text="Solo/Duo" Foreground="#3B82F6" FontSize="10" FontWeight="SemiBold"/>
                            </Border>

                            <!-- Tier + Rank -->
                            <TextBlock FontSize="22" FontWeight="Bold"
                                       Foreground="{Binding SoloRank.tier, Converter={StaticResource RankBrush}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="{Binding SoloRank.tier, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding SoloRank.rank, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="Non classé" FontSize="22" FontWeight="Bold" Foreground="#6B7280">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- LP · W · L · WinRate -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock FontSize="12" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Foreground" Value="#C9D1D9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding SoloRank.leaguePoints, Mode=OneWay}"/>
                                    <Run Text=" LP" Foreground="#6B7280"/>
                                </TextBlock>
                                <TextBlock Text=" · " Foreground="#30FFFFFF" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding SoloWins, Mode=OneWay}" Foreground="#C9D1D9" FontWeight="SemiBold"/>
                                    <Run Text="W" Foreground="#3FB950"/>
                                    <Run Text=" - " Foreground="#6B7280"/>
                                    <Run Text="{Binding SoloLosses, Mode=OneWay}" Foreground="#C9D1D9" FontWeight="SemiBold"/>
                                    <Run Text="L" Foreground="#F85149"/>
                                    <Run Text="  "/>
                                    <Run Text="{Binding SoloWinRate, Converter={StaticResource PctFmt}, Mode=OneWay}"
                                         Foreground="{Binding SoloWinRate, Converter={StaticResource WinRateBrush}}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Summoner name -->
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="{Binding GameName}" Foreground="#C9D1D9" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text=" #" Foreground="#6B7280" FontSize="12" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding TagLine}" Foreground="#6B7280" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Lanes -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                        Visibility="{Binding HasLaneData, Converter={StaticResource BoolVis}}">
                                <Border CornerRadius="4" Padding="7,2" Margin="0,0,5,0"
                                        Background="#20388BFD" BorderBrush="#40388BFD" BorderThickness="1">
                                    <TextBlock Text="{Binding PrimaryLane}" FontSize="11" FontWeight="SemiBold" Foreground="#388BFD"/>
                                </Border>
                                <Border CornerRadius="4" Padding="7,2"
                                        Background="#15AAAAAA" BorderBrush="#30AAAAAA" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SecondaryLane}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SecondaryLane}" FontSize="11" Foreground="#8B949E"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Colonne droite (Live badge + voir partie) -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                            <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Right"
                                    Background="#1A8B5CF6" BorderBrush="#408B5CF6" BorderThickness="1"
                                    Visibility="{Binding IsInGame, Converter={StaticResource BoolVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#8B5CF6" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#8B5CF6">
                                        <Run Text="EN PARTIE · "/>
                                        <Run Text="{Binding LiveTimerDisplay, Mode=OneWay}" FontFamily="Consolas"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Button HorizontalAlignment="Right" Margin="0,5,0,0" Padding="8,4" FontSize="11" Cursor="Hand"
                                    Visibility="{Binding IsInGame, Converter={StaticResource BoolVis}}"
                                    Command="{Binding DataContext.ViewLiveGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#1A8B5CF6"/>
                                        <Setter Property="Foreground" Value="#8B5CF6"/>
                                        <Setter Property="BorderBrush" Value="#408B5CF6"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#308B5CF6"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="👁 Voir la partie" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Separator -->
            <Rectangle Grid.Row="2" Height="1" Fill="#1E2435" Margin="16,0"/>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- BODY : Col gauche = matches  |  Col droite = stats            -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="275"/>
                </Grid.ColumnDefinitions>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- GAUCHE : Historique                                     -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <StackPanel Grid.Column="0" Margin="10,10,10,14">

                    <ItemsControl ItemsSource="{Binding RecentMatches}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" CornerRadius="7" Cursor="Hand"
                                        MouseLeftButtonDown="MatchRow_StopBubble">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Win}" Value="True">
                                                    <Setter Property="Background" Value="#0D3B82F6"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Win}" Value="False">
                                                    <Setter Property="Background" Value="#0DF85149"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#14FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.OpenMatchDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>

                                    <Grid Margin="6,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>    <!-- V/L bar -->
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="42"/>   <!-- Durée + ago -->
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="36"/>   <!-- Mon champ -->
                                            <ColumnDefinition Width="19"/>   <!-- Sorts -->
                                            <ColumnDefinition Width="17"/>   <!-- Rune -->
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/> <!-- K/D/A + KDA + mode -->
                                            <ColumnDefinition Width="*"/>    <!-- espace flexible -->
                                            <ColumnDefinition Width="Auto"/> <!-- Score + cercle -->
                                            <ColumnDefinition Width="Auto"/> <!-- VS + adversaire -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Bar V/L -->
                                        <Border Grid.Column="0" CornerRadius="2"
                                                Background="{Binding Win, Converter={StaticResource WinLossBrush}}"/>

                                        <!-- Durée + time ago -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding GameDuration, Converter={StaticResource GameDuration}}"
                                                       FontSize="11" FontWeight="Bold" Foreground="#C9D1D9" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding GameCreation, Converter={StaticResource TimeAgo}}"
                                                       FontSize="9" Foreground="#6B7280" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Mon champion -->
                                        <Border Grid.Column="4" Width="36" Height="36" CornerRadius="6"
                                                ClipToBounds="True" VerticalAlignment="Center"
                                                BorderBrush="#30FFFFFF" BorderThickness="1">
                                            <Image Source="{Binding ChampionName, Converter={StaticResource ChampToImg}}"
                                                   Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Sorts invocateurs -->
                                        <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="2,0">
                                            <Border Width="15" Height="15" CornerRadius="3" ClipToBounds="True" Margin="0,0,0,2">
                                                <Image Source="{Binding Summoner1Id, Converter={StaticResource SpellToImg}}" Stretch="UniformToFill"/>
                                            </Border>
                                            <Border Width="15" Height="15" CornerRadius="3" ClipToBounds="True">
                                                <Image Source="{Binding Summoner2Id, Converter={StaticResource SpellToImg}}" Stretch="UniformToFill"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Rune keystone -->
                                        <Border Grid.Column="6" Width="15" Height="15" CornerRadius="8"
                                                ClipToBounds="True" Background="#20FFFFFF" VerticalAlignment="Center">
                                            <Image Source="{Binding PrimaryRuneId, Converter={StaticResource RuneToImg}}" Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- K/D/A + KDA + mode (AVANT adversaire) -->
                                        <StackPanel Grid.Column="8" VerticalAlignment="Center">
                                            <TextBlock FontSize="12" FontWeight="SemiBold">
                                                <Run Text="{Binding Kills, Mode=OneWay}" Foreground="#C9D1D9"/>
                                                <Run Text=" / " Foreground="#6B7280"/>
                                                <Run Text="{Binding Deaths, Mode=OneWay}" Foreground="#F85149" FontWeight="Bold"/>
                                                <Run Text=" / " Foreground="#6B7280"/>
                                                <Run Text="{Binding Assists, Mode=OneWay}" Foreground="#C9D1D9"/>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                <TextBlock FontSize="10"
                                                           Text="{Binding KDA, Converter={StaticResource DblFmt}, Mode=OneWay}"
                                                           Foreground="{Binding KDA, Converter={StaticResource KdaBrush}}"/>
                                                <TextBlock Text=" KDA " FontSize="10" Foreground="#6B7280"/>
                                                <Border CornerRadius="3" Padding="4,1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#20AAAAAA"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding QueueId}" Value="420">
                                                                    <Setter Property="Background" Value="#1A3B82F6"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding QueueId}" Value="440">
                                                                    <Setter Property="Background" Value="#1A10B981"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding QueueId}" Value="450">
                                                                    <Setter Property="Background" Value="#1A8B5CF6"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding GameModeDisplay, Mode=OneWay}" FontSize="10" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#8B949E"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding QueueId}" Value="420">
                                                                        <Setter Property="Foreground" Value="#3B82F6"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding QueueId}" Value="440">
                                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding QueueId}" Value="450">
                                                                        <Setter Property="Foreground" Value="#8B5CF6"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Score + cercle (col 10) -->
                                        <StackPanel Grid.Column="10" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="4,0,0,0">
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,4,0">
                                                <TextBlock FontSize="15" FontWeight="Bold" HorizontalAlignment="Right">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#C9D1D9"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PerformanceScore}" Value="100">
                                                                    <Setter Property="Foreground" Value="#F5A623"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="{Binding PerformanceScore, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock HorizontalAlignment="Right" FontSize="9" Foreground="#6B7280">
                                                    <Run Text="{Binding CS, Mode=OneWay}"/>
                                                    <Run Text=" CS"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Grid Width="30" Height="30" VerticalAlignment="Center">
                                                <Ellipse StrokeThickness="2.5">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Stroke" Value="#30FFFFFF"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Win}" Value="True">
                                                                    <Setter Property="Stroke" Value="#3B82F6"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PerformanceScore}" Value="100">
                                                                    <Setter Property="Stroke" Value="#F5A623"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PerformanceScore}" Value="99">
                                                                    <Setter Property="Stroke" Value="#10B981"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="7" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value=""/>
                                                            <Setter Property="Foreground" Value="#6B7280"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PerformanceScore}" Value="100">
                                                                    <Setter Property="Text" Value="MVP"/>
                                                                    <Setter Property="Foreground" Value="#F5A623"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PerformanceScore}" Value="99">
                                                                    <Setter Property="Text" Value="ACE"/>
                                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>

                                        <!-- VS + Adversaire (col 11, tout à droite) -->
                                        <StackPanel Grid.Column="11" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="8,0,4,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OpponentChampionName}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="VS" FontSize="9" FontWeight="Bold"
                                                       Foreground="#6B7280" VerticalAlignment="Center"
                                                       Margin="0,0,5,0"/>
                                            <Border Width="26" Height="26" CornerRadius="13"
                                                    ClipToBounds="True" VerticalAlignment="Center"
                                                    BorderBrush="#20FFFFFF" BorderThickness="1">
                                                <Image Source="{Binding OpponentChampionName, Converter={StaticResource ChampToImg}}"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Bouton charger plus -->
                    <Button HorizontalAlignment="Center" Margin="0,8,0,0" Padding="14,6" FontSize="11" Cursor="Hand"
                            Command="{Binding DataContext.LoadMoreMatchesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1A3B82F6"/>
                                <Setter Property="Foreground" Value="#8B949E"/>
                                <Setter Property="BorderBrush" Value="#301E2435"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#25FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#40FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasMoreMatches}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLoadingMoreMatches}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value=""/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoadingMoreMatches}" Value="True">
                                                <Setter Property="Text" Value="⏳"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="⬇ Charger 10 parties suivantes"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoadingMoreMatches}" Value="True">
                                                <Setter Property="Text" Value="Chargement…"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Vertical separator -->
                <Rectangle Grid.Column="1" Fill="#1E2435"/>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- DROITE : Stats par champion + Coming soon               -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <StackPanel Grid.Column="2" Margin="14,12,14,14">

                    <!-- ── Header Stats par champion ── -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="⚔" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Stats par champion"
                                   Foreground="#C9D1D9" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Top 3 champions — style référence -->
                    <ItemsControl ItemsSource="{Binding TopChampionsFromHistory}"
                                  Visibility="{Binding HasChampionStats, Converter={StaticResource BoolVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2,0" CornerRadius="10" Background="#0D1117"
                                        BorderBrush="#1E2435" BorderThickness="1" Padding="8,12">
                                    <StackPanel HorizontalAlignment="Center">

                                        <!-- Champion icon — circulaire -->
                                        <Border Width="52" Height="52" CornerRadius="26"
                                                HorizontalAlignment="Center"
                                                BorderBrush="#50FFFFFF" BorderThickness="2"
                                                Background="#1AFFFFFF">
                                            <Border CornerRadius="24" ClipToBounds="True">
                                                <Image Source="{Binding ChampionName, Converter={StaticResource ChampToImg}}"
                                                       Stretch="UniformToFill"
                                                       Width="48" Height="48"/>
                                            </Border>
                                        </Border>

                                        <!-- Nom du champion -->
                                        <TextBlock Text="{Binding ChampionName}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#C9D1D9"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,6,0,4"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- W - L record -->
                                        <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="Bold">
                                            <Run Text="{Binding Wins, Mode=OneWay}" Foreground="#3FB950"/>
                                            <Run Text="W - " Foreground="#6B7280"/>
                                            <Run Text="{Binding Losses, Mode=OneWay}" Foreground="#F85149"/>
                                            <Run Text="L" Foreground="#6B7280"/>
                                        </TextBlock>

                                        <!-- KDA moyen -->
                                        <TextBlock HorizontalAlignment="Center" FontSize="10" Margin="0,3,0,0"
                                                   Foreground="{Binding KdaHex, Converter={StaticResource HexBrush}}">
                                            <Run Text="{Binding KdaDisplay, Mode=OneWay}"/>
                                        </TextBlock>

                                        <!-- Winrate % -->
                                        <TextBlock HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0"
                                                   Foreground="{Binding WinRateHex, Converter={StaticResource HexBrush}}">
                                            <Run Text="{Binding WinRateDisplay, Mode=OneWay}"/>
                                        </TextBlock>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Rectangle Height="1" Fill="#1E2435" Margin="0,14,0,14"/>

                    <!-- ══ LP Stats (pleine largeur) ══ -->
                    <Border CornerRadius="10" Background="#0D1117"
                            BorderBrush="#1E2435" BorderThickness="1"
                            Padding="10,10" Margin="0,0,0,6">
                        <StackPanel>

                            <!-- En-tête -->
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📈" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="LP Stats"
                                               Foreground="#C9D1D9"
                                               FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding LpTrackedGamesDisplay}"
                                           Foreground="#4B5563" FontSize="8"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Badges 7j / 30j -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 7 jours -->
                                <Border Grid.Column="0" CornerRadius="6" Padding="6,4"
                                        Background="#0F172A">
                                    <StackPanel>
                                        <TextBlock Text="7 JOURS" Foreground="#4B5563"
                                                   FontSize="8" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding LpDelta7dDisplay}"
                                                   FontSize="13" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{Binding LpDelta7dHex, Converter={StaticResource HexBrush}}"/>
                                    </StackPanel>
                                </Border>

                                <!-- 30 jours -->
                                <Border Grid.Column="2" CornerRadius="6" Padding="6,4"
                                        Background="#0F172A">
                                    <StackPanel>
                                        <TextBlock Text="30 JOURS" Foreground="#4B5563"
                                                   FontSize="8" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding LpDelta30dDisplay}"
                                                   FontSize="13" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{Binding LpDelta30dHex, Converter={StaticResource HexBrush}}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Courbe LP -->
<views:LpChartControl x:Name="LpChart"
    Height="90"
    Margin="0,0,0,4"
    Visibility="{Binding HasLpData, Converter={StaticResource BoolVis}}"/>

                            <!-- Placeholder si pas de données -->
                            <Border CornerRadius="6" Background="#0F172A" Padding="8,10" Margin="0,0,0,4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLpData}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="Joue une partie classée"
                                               Foreground="#6B7280" FontSize="9"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="pour démarrer le suivi LP"
                                               Foreground="#4B5563" FontSize="8"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Note approximation (visible uniquement si données seedées) -->
                            <TextBlock Text="* estimé depuis l'historique récent"
                                       Foreground="#374151" FontSize="7"
                                       HorizontalAlignment="Right"
                                       Visibility="{Binding HasLpData, Converter={StaticResource BoolVis}}"/>

                        </StackPanel>
                    </Border>

                    <!-- ══ Lens (coming soon) ══ -->
                    <Border CornerRadius="10" Background="#0D1117"
                            BorderBrush="#1E2435" BorderThickness="1"
                            Padding="6,12">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Lens" Foreground="#8B949E"
                                       FontSize="11" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Coming soon…" Foreground="#4B5563"
                                       FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>
