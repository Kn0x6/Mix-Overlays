<UserControl x:Class="MixOverlays.Views.DiamondPlayerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MixOverlays.Converters"
             Width="154" Height="236">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter             x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter      x:Key="InvBoolVis"/>
        <conv:RankTierBrushConverter                x:Key="RankBrush"/>
        <conv:WinRateBrushConverter                 x:Key="WinRateBrush"/>
        <conv:PercentFormatConverter                x:Key="PctFmt"/>
        <conv:ChampionNameToSplashConverter         x:Key="ChampSplash"/>
        <conv:SummonerSpellIdToImageConverter       x:Key="SpellToImg"/>
        <conv:RuneIdToImageConverter                x:Key="RuneToImg"/>
    </UserControl.Resources>

    <!-- Carte in-game style premium LoL. L'artwork est en UniformToFill pour remplir le cadre. -->
    <Grid Width="154" Height="236">

        <!-- Glow externe selon l'équipe -->
        <Border CornerRadius="18" BorderThickness="2" Background="#03070D">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="#32F5E7"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TeamId}" Value="200">
                            <Setter Property="BorderBrush" Value="#D9A14A"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- Corps de carte clipé pour que l'image ne sorte jamais du cadre -->
        <Border Margin="3" CornerRadius="16" ClipToBounds="True" Background="#08101C">
            <Grid>

                <!-- Splash art plein cadre : remplit la carte sans vide -->
                <Image Source="{Binding LiveChampionName, Converter={StaticResource ChampSplash}}"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.92"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <!-- Léger zoom centré : met en avant le sujet au milieu de l'artwork. -->
                        <ScaleTransform ScaleX="1.08" ScaleY="1.08"/>
                    </Image.RenderTransform>
                </Image>

                <!-- Overlays sombres pour lisibilité -->
                <Rectangle Fill="#55050B14"/>
                <Rectangle>
                    <Rectangle.Fill>
                        <!-- Centre volontairement plus clair, bords plus sombres. -->
                        <RadialGradientBrush Center="0.5,0.45" GradientOrigin="0.5,0.45" RadiusX="0.78" RadiusY="0.72">
                            <GradientStop Color="#00000000" Offset="0.0"/>
                            <GradientStop Color="#22000000" Offset="0.42"/>
                            <GradientStop Color="#99040A13" Offset="0.82"/>
                            <GradientStop Color="#DD040710" Offset="1.0"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#B8050B16" Offset="0.0"/>
                            <GradientStop Color="#22050B16" Offset="0.34"/>
                            <GradientStop Color="#55050B16" Offset="0.66"/>
                            <GradientStop Color="#E8050B16" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Bordure interne subtile -->
                <Border Margin="8" CornerRadius="12" BorderThickness="1.2" Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#6632F5E7"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TeamId}" Value="200">
                                    <Setter Property="BorderBrush" Value="#77D9A14A"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Décoration stable : pas de Polyline/DropShadow pour éviter les artefacts en fenêtre transparente. -->
                <Grid IsHitTestVisible="False" Margin="10" ClipToBounds="True">
                    <Rectangle Height="1" VerticalAlignment="Top" Margin="28,0" Opacity="0.55" Fill="#32F5E7"/>
                    <Rectangle Height="1" VerticalAlignment="Bottom" Margin="28,0" Opacity="0.45" Fill="#32F5E7"/>
                    <Rectangle Width="1" HorizontalAlignment="Left" Margin="0,28,0,34" Opacity="0.45" Fill="#32F5E7"/>
                    <Rectangle Width="1" HorizontalAlignment="Right" Margin="0,28,0,34" Opacity="0.45" Fill="#32F5E7"/>
                </Grid>

                <!-- Contenu principal -->
                <Grid Margin="12,8,12,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>

                    <!-- Haut : rune + sorts -->
                    <Grid Grid.Row="0">
                        <Border Width="25" Height="25" CornerRadius="13"
                                Background="#B7050B14"
                                BorderBrush="#6632F5E7" BorderThickness="1"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Visibility="{Binding HasLiveRune, Converter={StaticResource BoolVis}}">
                            <Image Source="{Binding LiveRuneId, Converter={StaticResource RuneToImg}}"
                                   Stretch="Uniform" Margin="3"/>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Border Width="25" Height="25" CornerRadius="4" ClipToBounds="True"
                                    Background="#AA000000" BorderBrush="#55F3D37A" BorderThickness="1" Margin="0,0,5,0">
                                <Image Source="{Binding LiveSpell1Id, Converter={StaticResource SpellToImg}}"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <Border Width="25" Height="25" CornerRadius="4" ClipToBounds="True"
                                    Background="#AA000000" BorderBrush="#55F3D37A" BorderThickness="1">
                                <Image Source="{Binding LiveSpell2Id, Converter={StaticResource SpellToImg}}"
                                       Stretch="UniformToFill"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Centre : identité, rang et stats -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Stretch">

                        <!-- Médaillon décoratif -->
                        <Grid Width="58" Height="58" HorizontalAlignment="Center" Margin="0,2,0,7">
                            <Ellipse Stroke="#7040EDE3" StrokeThickness="1.5" Fill="#66050B14"/>
                            <Ellipse Margin="6" Stroke="#D6F3D37A" StrokeThickness="2"/>
                            <Path Data="M29,9 L39,29 L29,49 L19,29 Z"
                                  Fill="#5532F5E7" Stroke="#E8F3D37A" StrokeThickness="1"/>
                        </Grid>

                        <TextBlock Text="{Binding GameName}"
                                   Foreground="#FFF8F0E0"
                                   FontSize="14" FontWeight="Bold"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="126"
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <Grid Height="12" Margin="4,5,4,3">
                            <Rectangle Height="1" VerticalAlignment="Center">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#0032F5E7" Offset="0"/>
                                        <GradientStop Color="#8832F5E7" Offset="0.38"/>
                                        <GradientStop Color="#CC32F5E7" Offset="0.5"/>
                                        <GradientStop Color="#8832F5E7" Offset="0.62"/>
                                        <GradientStop Color="#0032F5E7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5" Fill="#32F5E7">
                                <Rectangle.RenderTransform>
                                    <RotateTransform Angle="45"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>

                        <!-- Rang Solo/Duo -->
                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                                   FontSize="12" FontWeight="ExtraBold" Margin="0,0,0,1">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding SoloRank.tier, Mode=OneWay}"
                                 Foreground="{Binding SoloRank.tier, Converter={StaticResource RankBrush}}"/>
                            <Run Text=" " Foreground="White"/>
                            <Run Text="{Binding SoloRank.rank, Mode=OneWay}"
                                 Foreground="{Binding SoloRank.tier, Converter={StaticResource RankBrush}}"/>
                        </TextBlock>

                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"
                                   Foreground="#B9C2D1">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding SoloRank.leaguePoints, Mode=OneWay}"/>
                            <Run Text=" LP" Foreground="#778293"/>
                        </TextBlock>

                        <!-- Non classé -->
                        <TextBlock Text="NON CLASSE"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,6"
                                   Foreground="#8D96A8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Winrate + record -->
                        <Grid Margin="2,0,2,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="68"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SoloWinRate, Converter={StaticResource PctFmt}, Mode=OneWay}"
                                           Foreground="{Binding SoloWinRate, Converter={StaticResource WinRateBrush}}"
                                           FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                <TextBlock Text="WINRATE" Foreground="#6D788C"
                                           FontSize="7.5" FontWeight="Bold" TextAlignment="Center"/>
                            </StackPanel>

                            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Height="34">
                                <Rectangle Width="1" Fill="#5532F5E7"/>
                                <Rectangle Width="7" Height="7" Fill="#32F5E7" VerticalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <RotateTransform Angle="45"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock FontSize="10" FontWeight="Bold" TextAlignment="Center">
                                    <Run Text="{Binding SoloWins, Mode=OneWay}" Foreground="#36D88C"/>
                                    <Run Text=" V " Foreground="#36D88C"/>
                                    <Run Text="{Binding SoloLosses, Mode=OneWay}" Foreground="#FF6B6B"/>
                                    <Run Text=" D" Foreground="#FF6B6B"/>
                                </TextBlock>
                                <TextBlock Text="RECORD" Foreground="#6D788C"
                                           FontSize="7.5" FontWeight="Bold" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Bas : badge expertise intégré -->
                    <Border Grid.Row="2" Height="28" CornerRadius="8"
                            Background="#AA07111F"
                            BorderThickness="1"
                            VerticalAlignment="Bottom">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#5532F5E7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TeamId}" Value="200">
                                        <Setter Property="BorderBrush" Value="#66D9A14A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Rectangle Width="22" Height="1" HorizontalAlignment="Left" Margin="12,0,0,0"
                                       VerticalAlignment="Center" Fill="#5532F5E7"/>
                            <Rectangle Width="22" Height="1" HorizontalAlignment="Right" Margin="0,0,12,0"
                                       VerticalAlignment="Center" Fill="#5532F5E7"/>
                            <TextBlock Text="{Binding ExpertiseLabel}"
                                       FontSize="9" FontWeight="ExtraBold"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding ExpertiseBadgeForeground}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Skeleton de chargement -->
                <Border CornerRadius="16" Background="#E607101D"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.7">
                        <Border Width="72" Height="72" CornerRadius="36"
                                BorderBrush="#5532F5E7" BorderThickness="2"
                                Background="#283241" Margin="0,0,0,16"/>
                        <Border Width="100" Height="12" CornerRadius="6"
                                Background="#334155" Margin="0,0,0,10"/>
                        <Border Width="76" Height="10" CornerRadius="5"
                                Background="#334155" Margin="0,0,0,8"/>
                        <Border Width="112" Height="28" CornerRadius="8"
                                Background="#223044"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
