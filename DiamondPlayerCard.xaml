<UserControl x:Class="MixOverlays.Views.DiamondPlayerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MixOverlays.Converters"
             Width="130" Height="200">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter             x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter      x:Key="InvBoolVis"/>
        <conv:RankTierBrushConverter                x:Key="RankBrush"/>
        <conv:WinRateBrushConverter                 x:Key="WinRateBrush"/>
        <conv:PercentFormatConverter                x:Key="PctFmt"/>
        <conv:ChampionNameToSplashConverter         x:Key="ChampSplash"/>
        <conv:SummonerSpellIdToImageConverter       x:Key="SpellToImg"/>
        <conv:RuneIdToImageConverter                x:Key="RuneToImg"/>
    </UserControl.Resources>

    <Border CornerRadius="8" ClipToBounds="True">

        <!-- Bordure colorée selon l'équipe -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush"     Value="#4DC7DB"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding TeamId}" Value="200">
                        <Setter Property="BorderBrush" Value="#FF6B6B"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid Width="130" Height="200">

            <!-- ══ 1. Splash art du champion en fond ══ -->
            <!-- Uniform plutôt que UniformToFill : évite le zoom/crop excessif dans la carte portrait. -->
            <Image Stretch="Uniform" Opacity="0.65"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Source="{Binding LiveChampionName, Converter={StaticResource ChampSplash}}"/>

            <!-- ══ 2. Dégradé sombre pour lisibilité ══ -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#EE0A0E1A" Offset="0.0"/>
                        <GradientStop Color="#880A0E1A" Offset="0.4"/>
                        <GradientStop Color="#EE0A0E1A" Offset="1.0"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ══ 3. Contenu ══ -->
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Haut : rune + spells -->
                    <RowDefinition Height="36"/>
                    <!-- Milieu : nom + rang -->
                    <RowDefinition Height="*"/>
                    <!-- Bas : badge expertise -->
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <!-- ── Ligne 1 : Rune keystone (gauche) + Spells (droite) ── -->
                <Grid Grid.Row="0" Margin="8,6,8,0">
                    <!-- Rune -->
                    <Border Width="24" Height="24" CornerRadius="12"
                            Background="#BB000000"
                            BorderBrush="#40FFFFFF" BorderThickness="1"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Visibility="{Binding HasLiveRune, Converter={StaticResource BoolVis}}">
                        <Image Source="{Binding LiveRuneId, Converter={StaticResource RuneToImg}}"
                               Stretch="Uniform" Margin="2"/>
                    </Border>

                    <!-- Spells -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Width="20" Height="20" CornerRadius="3"
                                ClipToBounds="True" Margin="0,0,3,0"
                                Background="#66000000">
                            <Image Source="{Binding LiveSpell1Id, Converter={StaticResource SpellToImg}}"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <Border Width="20" Height="20" CornerRadius="3"
                                ClipToBounds="True"
                                Background="#66000000">
                            <Image Source="{Binding LiveSpell2Id, Converter={StaticResource SpellToImg}}"
                                   Stretch="UniformToFill"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ── Ligne 2 : Nom + Rang ── -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Margin="6,0">

                    <!-- Nom du joueur -->
                    <TextBlock Text="{Binding GameName}"
                               Foreground="White" FontSize="12" FontWeight="Bold"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="118"
                               HorizontalAlignment="Center"/>

                    <!-- Rang Solo/Duo (tier + rank + LP) -->
                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding SoloRank.tier,         Mode=OneWay}"
                             Foreground="{Binding SoloRank.tier, Converter={StaticResource RankBrush}}"/>
                        <Run Text=" "  Foreground="White"/>
                        <Run Text="{Binding SoloRank.rank,         Mode=OneWay}"
                             Foreground="{Binding SoloRank.tier, Converter={StaticResource RankBrush}}"/>
                    </TextBlock>

                    <!-- LP -->
                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                               FontSize="10" Margin="0,1,0,0" Foreground="#A0B0C0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding SoloRank.leaguePoints, Mode=OneWay}"/>
                        <Run Text=" LP" Foreground="#6B7280"/>
                    </TextBlock>

                    <!-- Winrate saison -->
                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                               FontSize="10" Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding SoloWinRate, Converter={StaticResource PctFmt}, Mode=OneWay}"
                             Foreground="{Binding SoloWinRate, Converter={StaticResource WinRateBrush}}"/>
                        <Run Text=" (" Foreground="#6B7280"/>
                        <Run Text="{Binding SoloWins,   Mode=OneWay}" Foreground="#4ADE80"/>
                        <Run Text="V "                               Foreground="#4ADE80"/>
                        <Run Text="{Binding SoloLosses, Mode=OneWay}" Foreground="#F87171"/>
                        <Run Text="D)"                               Foreground="#F87171"/>
                    </TextBlock>

                    <!-- Non classé (quand SoloRank est null) -->
                    <TextBlock Text="Non classé"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               FontSize="10" Margin="0,3,0,0" Foreground="#6B7280">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SoloRank}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>

                <!-- ── Ligne 3 : Badge expertise ── -->
                <Border Grid.Row="2"
                        Background="{Binding ExpertiseBadgeBackground}"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch">
                    <TextBlock Text="{Binding ExpertiseLabel}"
                               FontSize="9" FontWeight="Bold"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{Binding ExpertiseBadgeForeground}"/>
                </Border>
            </Grid>

            <!-- ══ 4. Skeleton de chargement ══ -->
            <Border CornerRadius="8" Background="#CC0D1117"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.6">
                    <Border Width="80" Height="10" CornerRadius="5"
                            Background="#334155" Margin="0,0,0,10"/>
                    <Border Width="60" Height="8"  CornerRadius="4"
                            Background="#334155" Margin="0,0,0,8"/>
                    <Border Width="70" Height="8"  CornerRadius="4"
                            Background="#334155"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>

</UserControl>
