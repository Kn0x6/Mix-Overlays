<Window x:Class="MixOverlays.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MixOverlays.ViewModels"
        xmlns:views="clr-namespace:MixOverlays.Views"
        xmlns:conv="clr-namespace:MixOverlays.Converters"
        Title="MixOverlays" Icon="/Icone.ico" Height="920" Width="1720"
        MinWidth="1180" MinHeight="720"
        Background="Transparent"
        FontFamily="{StaticResource PrimaryFont}"
        WindowStyle="None" AllowsTransparency="True"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:BoolToVisibilityConverter         x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter  x:Key="InvBoolVis"/>
        <conv:NullToVisibilityConverter         x:Key="NullVis"/>
        <conv:HexStringToBrushConverter         x:Key="HexBrush"/>
        <conv:DoubleFormatConverter             x:Key="DoubleFmt"/>
        <conv:TimeAgoConverter                  x:Key="TimeAgo"/>
        <conv:GameDurationConverter             x:Key="GameDuration"/>
        <conv:ChampionNameToImageConverter      x:Key="ChampImg"/>
        <conv:ChampionIdToImageConverter        x:Key="ChampIdImg"/>
        <conv:SummonerSpellIdToImageConverter   x:Key="SpellImg"/>
        <conv:RuneIdToImageConverter            x:Key="RuneToImg"/>
        <conv:RuneIdToNameConverter             x:Key="RuneToName"/>
        <conv:ItemIdToImageConverter            x:Key="ItemToImg"/>
        <conv:UrlToImageSourceWithFallbackConverter x:Key="UrlToImgWithFallback"/>
        <conv:WinLossBrushConverter             x:Key="WinLossBrush"/>
        <conv:PercentageToGridLengthConverter   x:Key="PercentToGridLength"/>
    </Window.Resources>

    <Border x:Name="MainWindowRoot"
            Background="{StaticResource BgDeepBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14"
            SizeChanged="MainWindowRoot_SizeChanged">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════ -->
            <!--  TITLE BAR                                             -->
            <!-- ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                    CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="22,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="24" Height="24" Margin="0,0,8,0">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#35D6FF" Offset="0"/>
                                    <GradientStop Color="#D946EF" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="MixOverlays"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" FontSize="16"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Status indicator -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                 Fill="{Binding StatusDotColor, Converter={StaticResource HexBrush}}"/>
                        <TextBlock Text="{Binding ClientStateDisplay}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowChromeButton}"
                                Click="SettingsButton_Click" ToolTip="Paramètres"
                                AutomationProperties.Name="Ouvrir les paramètres">
                            <Viewbox Width="14" Height="14">
                                <Path Data="M 7,1 L 8,3 L 10,3 L 11,5 L 10,7 L 11,9 L 10,11 L 8,11 L 7,13 L 5,11 L 3,11 L 2,9 L 3,7 L 2,5 L 3,3 L 5,3 Z M 7,5 A 2,2 0 1 1 6.9,5"
                                      Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.2" Fill="Transparent"/>
                            </Viewbox>
                        </Button>
                        <Button Content="─" Style="{StaticResource WindowChromeButton}"
                                Click="MinimizeButton_Click" FontSize="14"/>
                        <Button x:Name="BtnFullscreen" Content="⛶" Style="{StaticResource WindowChromeButton}"
                                Click="FullscreenButton_Click" FontSize="13" ToolTip="Plein écran"/>
                        <Button Content="✕" Style="{StaticResource WindowChromeButton}"
                                Click="CloseButton_Click" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════ -->
            <!--  MAIN CONTENT                                          -->
            <!-- ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Background="{StaticResource BgDeepBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="198"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0"/>      <!-- Ancienne barre d'onglets masquée -->
                    <RowDefinition Height="*"/>      <!-- Content -->
                </Grid.RowDefinitions>

                <!-- ─── SIDEBAR style launcher ─── -->
                <Border Grid.RowSpan="2" Grid.Column="0"
                        Background="{StaticResource SidebarBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,26,0,0">
                            <Button x:Name="BtnSideMyAccount" Style="{StaticResource SideNavButton}"
                                    Click="NavButton_Click" Tag="MyAccount">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,8,0" Background="#1C4F9F">
                                        <TextBlock Text="⌂" Foreground="#7DB7FF" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Mon Compte" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSideDashboard" Style="{StaticResource SideNavButton}"
                                    Click="NavButton_Click" Tag="Dashboard">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▣" Width="36" FontSize="20" VerticalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSideHistory" Style="{StaticResource SideNavButton}"
                                    Click="NavButton_Click" Tag="History">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="◷" Width="36" FontSize="23" VerticalAlignment="Center" TextAlignment="Center" Foreground="#8B5CF6"/>
                                    <TextBlock Text="Historique" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSideChampions" Style="{StaticResource SideNavButton}"
                                    Click="NavButton_Click" Tag="Champions">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✿" Width="36" FontSize="18" VerticalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="Champions" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSideStats" Style="{StaticResource SideNavButton}"
                                    Click="NavButton_Click" Tag="Stats">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▥" Width="36" FontSize="20" VerticalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="Stats" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSideAnalysis" Style="{StaticResource SideNavButton}"
                                    Click="NavButton_Click" Tag="Analysis">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="◔" Width="36" FontSize="22" VerticalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="Analyse" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSideCompare" Style="{StaticResource SideNavButton}"
                                    Click="NavButton_Click" Tag="Compare">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="◌" Width="36" FontSize="22" VerticalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="Comparateur" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSideLive" Style="{StaticResource SideNavButton}"
                                    Click="NavButton_Click" Tag="Live"
                                    Visibility="{Binding IsLiveSessionAvailable, Converter={StaticResource BoolVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶" Width="36" FontSize="18" VerticalAlignment="Center" TextAlignment="Center" Foreground="#3FB950"/>
                                    <TextBlock Text="Live Session" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSideSettings" Style="{StaticResource SideNavButton}"
                                    Click="NavButton_Click" Tag="Settings">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙" Width="36" FontSize="19" VerticalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="Paramètres" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2" Margin="10,0,16,12" Padding="12" CornerRadius="10"
                                Background="#101A31" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Width="40" Height="40" Margin="0,0,9,0">
                                        <Ellipse.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#22D3EE" Offset="0"/>
                                                <GradientStop Color="#7C3AED" Offset="0.55"/>
                                                <GradientStop Color="#D946EF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="MixOverlays" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="PRO  · v1.0" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="9" Height="9" Margin="0,0,6,0" VerticalAlignment="Center"
                                             Fill="{Binding StatusDotColor, Converter={StaticResource HexBrush}}"/>
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11" TextTrimming="CharacterEllipsis" ToolTip="{Binding StatusMessage}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ─── TOP NAV BAR masquée : Mon Compte devient la page principale ─── -->
                <Border Grid.Row="0" Grid.Column="1"
                        Visibility="Collapsed"
                        Background="{StaticResource BgPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Boutons de navigation -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0">
                            <Button x:Name="BtnMyAccount" Content="👤  Mon Compte"
                                    Style="{StaticResource NavButton}"
                                    Click="NavButton_Click" Tag="MyAccount"/>
                            <Button x:Name="BtnLive" Content="🎮  Live Session"
                                    Style="{StaticResource NavButton}"
                                    Click="NavButton_Click" Tag="Live"
                                    Visibility="{Binding IsLiveSessionAvailable, Converter={StaticResource BoolVis}}"/>
                            <Button x:Name="BtnSearch" Content="🔍  Rechercher"
                                    Style="{StaticResource NavButton}"
                                    Click="NavButton_Click" Tag="Search"/>
                            <Button x:Name="BtnSettings" Content="⚙  Paramètres"
                                    Style="{StaticResource NavButton}"
                                    Click="NavButton_Click" Tag="Settings"/>
                        </StackPanel>

                        <!-- LCU Status compact à droite -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,16,0">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                     Fill="{Binding StatusDotColor, Converter={StaticResource HexBrush}}"/>
                            <TextBlock Text="{Binding ClientStateDisplay}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="10" VerticalAlignment="Center"
                                       Margin="10,0,0,0" MaxWidth="220"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─── PAGES ─── -->
                <Grid Grid.Row="1" Grid.Column="1" Margin="18,16,18,16">
                    <!-- PageLive -->
                    <Grid x:Name="PageLive">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource BgPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="16,10">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Live Session"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Style="{StaticResource PageTitle}"
                                               VerticalAlignment="Center"/>
                                    <Border Margin="12,0,0,0" Padding="8,3" CornerRadius="12"
                                            Background="{StaticResource BgCardBrush}">
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="{Binding AllyTeam.Count, Mode=OneWay}"/>
                                            <Run Text=" alliés ·"/>
                                            <Run Text="{Binding EnemyTeam.Count, Mode=OneWay}"/>
                                            <Run Text=" ennemis"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>

                                <Button Content="←  Mon Compte"
                                        Style="{StaticResource GhostButton}"
                                        Click="BackToMyAccountButton_Click"
                                        HorizontalAlignment="Right"
                                        Padding="10,5"/>
                            </Grid>
                        </Border>

                        <!-- Recommandations Champion Select -->
                        <Border Grid.Row="1"
                                Visibility="{Binding ShowChampionRecommendationPanel, Converter={StaticResource BoolVis}}"
                                Background="{StaticResource BgSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="44" Height="44"
                                        CornerRadius="7" ClipToBounds="True"
                                        Background="{StaticResource BgCardBrush}"
                                        Margin="0,0,12,0">
                                    <Image Source="{Binding LockedChampionId, Converter={StaticResource ChampIdImg}}"
                                           Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasDetectedChampionForRecommendation}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="RUNES RECOMMANDÉES · "
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding LockedChampionName}"
                                                   Foreground="#FF8C5A"
                                                   FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Text="  •  " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding LockedChampionRoleDisplay}"
                                                   Foreground="{StaticResource AccentBlueLightBrush}"
                                                   FontSize="12" FontWeight="Bold"/>
                                    </StackPanel>

                                    <TextBlock Text="En attente du verrouillage de votre champion..."
                                               Visibility="{Binding IsWaitingForChampionLock, Converter={StaticResource BoolVis}}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"/>

                                    <TextBlock Text="Chargement des runes et du build communautaire..."
                                               Visibility="{Binding IsLoadingChampionRecommendation, Converter={StaticResource BoolVis}}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"/>

                                    <TextBlock Text="{Binding ChampionRecommendationError}"
                                               Visibility="{Binding HasChampionRecommendationError, Converter={StaticResource BoolVis}}"
                                               Foreground="#F85149"
                                               FontSize="11"/>

                                    <StackPanel Visibility="{Binding HasChampionRecommendation, Converter={StaticResource BoolVis}}">
                                        <Grid Margin="0,0,0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="ARBRE PRINCIPAL" Style="{StaticResource SectionLabel}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding ChampionRecommendation.PrimaryStyleName}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,3"/>
                                                <ItemsControl ItemsSource="{Binding ChampionRecommendation.PrimaryRuneIds}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                                <Border Width="21" Height="21" CornerRadius="11" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True" Margin="0,0,5,0">
                                                                    <Image Source="{Binding Converter={StaticResource RuneToImg}}" Stretch="UniformToFill"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Converter={StaticResource RuneToName}}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="ARBRE SECONDAIRE" Style="{StaticResource SectionLabel}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding ChampionRecommendation.SecondaryStyleName}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,3"/>
                                                <ItemsControl ItemsSource="{Binding ChampionRecommendation.SecondaryRuneIds}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                                <Border Width="21" Height="21" CornerRadius="11" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True" Margin="0,0,5,0">
                                                                    <Image Source="{Binding Converter={StaticResource RuneToImg}}" Stretch="UniformToFill"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Converter={StaticResource RuneToName}}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="FRAGMENTS" Style="{StaticResource SectionLabel}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <ItemsControl ItemsSource="{Binding ChampionRecommendation.ShardIds}">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate><DataTemplate>
                                                    <Border Width="22" Height="22" CornerRadius="4" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True" Margin="0,0,4,0">
                                                        <Image Source="{Binding Converter={StaticResource RuneToImg}}" Stretch="UniformToFill"/>
                                                    </Border>
                                                </DataTemplate></ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="  Winrate : " Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ChampionRecommendation.WinRateDisplay}" Foreground="{StaticResource WinLightBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Text="  •  Parties : " Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ChampionRecommendation.GameCountDisplay}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <WrapPanel Visibility="Collapsed">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                                                <TextBlock Text="Start"
                                                           Style="{StaticResource SectionLabel}"
                                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <ItemsControl ItemsSource="{Binding ChampionRecommendation.StartingItemIds}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="24" Height="24" CornerRadius="4"
                                                                    ClipToBounds="True" Margin="0,0,4,0"
                                                                    Background="{StaticResource BgCardBrush}">
                                                                <Image Source="{Binding Converter={StaticResource ItemToImg}}" Stretch="UniformToFill"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                                                <TextBlock Text="Bottes"
                                                           Style="{StaticResource SectionLabel}"
                                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <ItemsControl ItemsSource="{Binding ChampionRecommendation.BootsItemIds}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="24" Height="24" CornerRadius="4"
                                                                    ClipToBounds="True" Margin="0,0,4,0"
                                                                    Background="{StaticResource BgCardBrush}">
                                                                <Image Source="{Binding Converter={StaticResource ItemToImg}}" Stretch="UniformToFill"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                                                <TextBlock Text="Core"
                                                           Style="{StaticResource SectionLabel}"
                                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <ItemsControl ItemsSource="{Binding ChampionRecommendation.CoreItemIds}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="24" Height="24" CornerRadius="4"
                                                                    ClipToBounds="True" Margin="0,0,4,0"
                                                                    Background="{StaticResource BgCardBrush}">
                                                                <Image Source="{Binding Converter={StaticResource ItemToImg}}" Stretch="UniformToFill"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </WrapPanel>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                            Visibility="{Binding HasChampionRecommendation, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="SOURCE"
                                               Style="{StaticResource SectionLabel}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding ChampionRecommendation.SourceName}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" HorizontalAlignment="Right"/>
                                    <TextBlock Text="fallback"
                                               Foreground="#F59E0B"
                                               FontSize="10" HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ChampionRecommendation.IsFallback}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Command="{Binding ImportRunesCommand}"
                                            Content="COPIER LES RUNES"
                                            Padding="10,5" Margin="0,7,0,0"
                                            FontSize="11" FontWeight="SemiBold">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                                <Setter Property="Content" Value="COPIER LES RUNES"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsImportingRunes}" Value="True">
                                                        <Setter Property="Content" Value="IMPORT EN COURS…"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Text="{Binding RuneImportStatus}"
                                               Visibility="{Binding HasRuneImportStatus, Converter={StaticResource BoolVis}}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10" TextWrapping="Wrap" TextAlignment="Right"
                                               MaxWidth="155" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Empty state -->
                        <StackPanel Grid.Row="2"
                                    Visibility="{Binding IsInLiveSession, Converter={StaticResource InvBoolVis}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.72">
                            <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="En attente d'une session..." Margin="0,12,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="Lancez ou rejoignez une partie pour voir les stats des joueurs"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Teams columns -->
                        <Grid Grid.Row="2"
                              Visibility="{Binding IsInLiveSession, Converter={StaticResource BoolVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Ally team -->
                            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,1,0">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Padding="12,8"
                                            Background="{StaticResource BgSecondaryBrush}">
                                        <TextBlock Text="🔵  ALLIÉS"
                                                   Foreground="#388BFD"
                                                   FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  Style="{StaticResource SlimScrollViewer}">
                                        <ItemsControl ItemsSource="{Binding AllyTeam}" Margin="8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <views:LivePlayerCard DataContext="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>

                            <!-- Enemy team -->
                            <DockPanel Grid.Column="1">
                                <Border DockPanel.Dock="Top" Padding="12,8"
                                        Background="{StaticResource BgSecondaryBrush}">
                                    <TextBlock Text="🔴  ENNEMIS"
                                               Foreground="#F85149"
                                               FontSize="11" FontWeight="Bold"/>
                                </Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Style="{StaticResource SlimScrollViewer}">
                                    <ItemsControl ItemsSource="{Binding EnemyTeam}" Margin="8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <views:LivePlayerCard DataContext="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Grid>
                    </Grid>

                    <!-- MON COMPTE PAGE -->
                    <Grid x:Name="PageMyAccount" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="Transparent"
                                Padding="10,0,4,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Mon Compte"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="25" FontWeight="SemiBold"/>
                                    <TextBlock Text="Historique de vos parties classées"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="13" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="1" Content="🎮  Live"
                                        Style="{StaticResource HeaderActionButton}"
                                        Click="OpenLiveSessionButton_Click"
                                        Visibility="{Binding IsLiveSessionAvailable, Converter={StaticResource BoolVis}}"
                                        ToolTip="Afficher la Live Session"
                                        Padding="10,5" Margin="0,0,6,0"/>

                                <TextBox Grid.Column="2"
                                         Width="240" Height="44"
                                         Text="{Binding SearchInput, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,6,0"
                                         VerticalAlignment="Center"
                                         KeyDown="SearchBox_KeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Style.Resources>
                                                <VisualBrush x:Key="HeaderSearchPlaceholderBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Rechercher un joueur"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   Margin="10,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Style.Resources>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource HeaderSearchPlaceholderBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <Button Grid.Column="3" Content="🔍"
                                        Style="{StaticResource HeaderActionButton}"
                                        Click="SearchPlayerButton_Click"
                                        ToolTip="Rechercher"
                                        Width="36" Padding="0" Margin="0,0,6,0"/>

                                <Button Grid.Column="4" Content="✕"
                                        Style="{StaticResource HeaderActionButton}"
                                        Width="36" Padding="0" Margin="0,0,6,0"
                                        Command="{Binding ClearSearchCommand}"
                                        ToolTip="Effacer la recherche"
                                        Visibility="{Binding HasSearchResult, Converter={StaticResource BoolVis}}"/>

                                <Button Grid.Column="5" Content="🔄  Actualiser"
                                        Style="{StaticResource HeaderActionButton}"
                                        Command="{Binding RefreshMyAccountCommand}"
                                        HorizontalAlignment="Right"
                                        Padding="10,5"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>         <!-- Fiche joueur -->
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0"
                                          VerticalScrollBarVisibility="Auto"
                                          Style="{StaticResource SlimScrollViewer}">
                                <StackPanel Margin="0">
                                    <Grid>
                                        <!-- Loading skeleton -->
                                        <StackPanel Visibility="{Binding IsLoadingMyAccount, Converter={StaticResource BoolVis}}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                                    Margin="0,40" Opacity="0.6">
                                            <TextBlock Text="⏳ Chargement..."
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="13" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Error -->
                                        <Border Visibility="{Binding HasMyAccountError, Converter={StaticResource BoolVis}}"
                                                Background="#1AF85149" BorderBrush="#F85149" BorderThickness="1"
                                                CornerRadius="8" Padding="16" Margin="0,20">
                                            <TextBlock Text="{Binding MyAccountError}"
                                                       Foreground="#F85149" FontSize="13" TextWrapping="Wrap"/>
                                        </Border>
                                        <!-- Not connected -->
                                        <StackPanel Visibility="{Binding HasMyAccount, Converter={StaticResource InvBoolVis}}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                                    Margin="0,60" Opacity="0.72">
                                            <TextBlock Text="🔌" FontSize="48" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Client LoL non connecté"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                            <TextBlock Text="Lancez le client League of Legends"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            <TextBlock Text="Dernier profil connu affiché en mode hors-ligne"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                       Visibility="{Binding IsConnected, Converter={StaticResource InvBoolVis}}"/>
                                        </StackPanel>
                                        <!-- Fiche joueur -->
                                        <views:PlayerCard DataContext="{Binding MyAccount}"
                                                          Visibility="{Binding DataContext.HasMyAccount,
                                               RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                               Converter={StaticResource BoolVis}}"/>
                                    </Grid>

                                    <!-- Résultat de recherche masqué ici : la recherche s'affiche en premier plan via PageSearch -->
                                    <Border Visibility="Collapsed"
                                            Background="{StaticResource BgPrimaryBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12"
                                            Margin="0,16,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasSearchResult}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasSearchHistory}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <TextBlock Text="RECHERCHE JOUEUR"
                                                       Style="{StaticResource SectionLabel}"
                                                       Margin="0,0,0,10"/>

                                            <StackPanel Visibility="{Binding IsSearching, Converter={StaticResource BoolVis}}"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,18">
                                                <TextBlock Text="⏳ Chargement des données..."
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="14" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <views:PlayerCard DataContext="{Binding SearchedPlayer}"
                                                              Visibility="{Binding DataContext.HasSearchResult,
                                                   RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                                   Converter={StaticResource BoolVis}}"/>

                                            <Border Visibility="{Binding ShowSearchHistory, Converter={StaticResource BoolVis}}"
                                                    Background="{StaticResource BgCardBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="HISTORIQUE DES RECHERCHES"
                                                               Style="{StaticResource SectionLabel}"
                                                               Margin="0,0,0,8"/>

                                                    <ListBox ItemsSource="{Binding SearchHistory}"
                                                             SelectedItem="{Binding SelectedHistoryPlayer, Mode=TwoWay}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Padding="0"
                                                             MaxHeight="170"
                                                             HorizontalContentAlignment="Stretch"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Margin" Value="0,0,0,6"/>
                                                                <Setter Property="Padding" Value="0"/>
                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ListBoxItem">
                                                                            <ContentPresenter/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderBrush="{StaticResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="10,8">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="{StaticResource BgPrimaryBrush}"/>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Width="34" Height="34"
                                                                                CornerRadius="17"
                                                                                BorderBrush="{StaticResource AccentBlueLightBrush}"
                                                                                BorderThickness="1"
                                                                                ClipToBounds="True"
                                                                                Margin="0,0,10,0">
                                                                            <Image Source="{Binding ProfileIconUrl, Converter={StaticResource UrlToImgWithFallback}}"
                                                                                   Stretch="UniformToFill"/>
                                                                        </Border>

                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                                   FontSize="13"
                                                                                   FontWeight="SemiBold"
                                                                                   VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- SEARCH PAGE -->
                    <Grid x:Name="PageSearch" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource BgPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="16,10">
                            <Grid>
                                <TextBlock Text="Joueur recherché"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Style="{StaticResource PageTitle}"
                                           VerticalAlignment="Center"/>
                                <Button Content="←  Mon Compte"
                                        Style="{StaticResource GhostButton}"
                                        Click="BackToMyAccountButton_Click"
                                        HorizontalAlignment="Right"
                                        Padding="10,5"/>
                            </Grid>
                        </Border>

                        <!-- Search bar -->
                        <Border Grid.Row="1" Padding="16,12"
                                Background="{StaticResource BgPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding SearchInput, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,8,0"
                                         KeyDown="SearchBox_KeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Style.Resources>
                                                <VisualBrush x:Key="PlaceholderBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Nom#TAG ou NomInvocateur"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   Margin="10,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Style.Resources>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <Button Grid.Column="1" Content="Rechercher"
                                        Style="{StaticResource AccentButton}"
                                        Click="SearchPlayerButton_Click"
                                        Margin="0,0,6,0"/>

                                <Button Grid.Column="2" Content="✕"
                                        Style="{StaticResource GhostButton}"
                                        Width="36"
                                        Command="{Binding ClearSearchCommand}"
                                        Visibility="{Binding HasSearchResult, Converter={StaticResource BoolVis}}"/>
                            </Grid>
                        </Border>

                        <!-- Result -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>      <!-- Fiche joueur -->
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0"
                                          VerticalScrollBarVisibility="Auto"
                                          Style="{StaticResource SlimScrollViewer}">
                                <StackPanel Margin="16">
                                    <!-- Loading -->
                                    <StackPanel Visibility="{Binding IsSearching, Converter={StaticResource BoolVis}}"
                                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                                Margin="0,40">
                                        <TextBlock Text="⏳ Chargement des données..."
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="14" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Historique des recherches : plus récent en haut -->
                                    <Border Visibility="{Binding ShowSearchHistory, Converter={StaticResource BoolVis}}"
                                            Background="{StaticResource BgPrimaryBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12"
                                            Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="HISTORIQUE DES RECHERCHES"
                                                       Style="{StaticResource SectionLabel}"
                                                       Margin="0,0,0,8"/>

                                            <ListBox ItemsSource="{Binding SearchHistory}"
                                                     SelectedItem="{Binding SelectedHistoryPlayer, Mode=TwoWay}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="0"
                                                     HorizontalContentAlignment="Stretch"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel/>
                                                    </ItemsPanelTemplate>
                                                </ListBox.ItemsPanel>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <ContentPresenter/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="10,8">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                                                                    <Setter Property="Opacity" Value="0.95"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                                            <Setter Property="Opacity" Value="1"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="34" Height="34"
                                                                        CornerRadius="17"
                                                                        BorderBrush="{StaticResource AccentBlueLightBrush}"
                                                                        BorderThickness="1"
                                                                        ClipToBounds="True"
                                                                        Margin="0,0,10,0">
                                                                    <Image Source="{Binding ProfileIconUrl, Converter={StaticResource UrlToImgWithFallback}}"
                                                                           Stretch="UniformToFill"/>
                                                                </Border>

                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>

                                    <!-- Résultat -->
                                    <views:PlayerCard DataContext="{Binding SearchedPlayer}"
                                                      Visibility="{Binding DataContext.HasSearchResult,
                                           RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                           Converter={StaticResource BoolVis}}"/>
                                    <!-- Empty state -->
                                    <StackPanel Visibility="{Binding ShowSearchEmptyState, Converter={StaticResource BoolVis}}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Opacity="0.72" Margin="0,60">
                                        <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Entrez un Riot ID pour rechercher un joueur"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                        <TextBlock Text="Format : NomDeJoueur#EUW ou NomDeJoueur#FR1"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- SETTINGS PAGE -->
                    <Grid x:Name="PageSettings" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource BgPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="16,10">
                            <Grid>
                                <TextBlock Text="Paramètres"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Style="{StaticResource PageTitle}"
                                           VerticalAlignment="Center"/>
                                <Button Content="←  Retour Mon Compte"
                                        Style="{StaticResource GhostButton}"
                                        Click="BackToMyAccountButton_Click"
                                        HorizontalAlignment="Right"
                                        Padding="10,5"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      Style="{StaticResource SlimScrollViewer}">
                            <StackPanel Margin="24,20" MaxWidth="560">

                                <!-- API Key section -->
                                <TextBlock Text="API RIOT"
                                           Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>

                                <Border Background="{StaticResource BgCardBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="10"
                                        Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Clé API Riot Developer"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="13" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding Settings.RiotApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="🔑  Tester la clé"
                                                    Style="{StaticResource GhostButton}"
                                                    Command="{Binding TestApiKeyCommand}"
                                                    Padding="10,5" FontSize="12"/>
                                            <Border x:Name="ApiTestResult" Margin="10,0,0,0"
                                                    Padding="8,4" CornerRadius="6"
                                                    Visibility="{Binding ApiTestMessage, Converter={StaticResource NullVis}}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1A3FB950"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ApiTestSuccess}" Value="False">
                                                                <Setter Property="Background" Value="#1AF85149"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding ApiTestMessage}"
                                                           FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#3FB950"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ApiTestSuccess}" Value="False">
                                                                    <Setter Property="Foreground" Value="#F85149"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}">
                                            Obtenez votre clé sur
                                            <Hyperlink NavigateUri="https://developer.riotgames.com"
                                                       RequestNavigate="Hyperlink_RequestNavigate"
                                                       Foreground="{StaticResource AccentBlueLightBrush}">
                                                developer.riotgames.com
                                            </Hyperlink>
                                            — Les clés de dev expirent toutes les 24h.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Region section -->
                                <TextBlock Text="RÉGION"
                                           Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>

                                <Border Background="{StaticResource BgCardBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="10"
                                        Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Serveur / Région"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="13" Margin="0,0,0,6"/>
                                        <ComboBox SelectedValue="{Binding Settings.Region}"
                                                  SelectedValuePath="Content"
                                                  HorizontalAlignment="Left" Width="160">
                                            <ComboBoxItem Content="EUW1"/>
                                            <ComboBoxItem Content="EUN1"/>
                                            <ComboBoxItem Content="NA1"/>
                                            <ComboBoxItem Content="KR"/>
                                            <ComboBoxItem Content="JP1"/>
                                            <ComboBoxItem Content="BR1"/>
                                            <ComboBoxItem Content="LA1"/>
                                            <ComboBoxItem Content="LA2"/>
                                            <ComboBoxItem Content="OC1"/>
                                            <ComboBoxItem Content="TR1"/>
                                            <ComboBoxItem Content="RU"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- Overlay section -->
                                <TextBlock Text="OVERLAY IN-GAME"
                                           Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>

                                <Border Background="{StaticResource BgCardBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="10"
                                        Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <CheckBox IsChecked="{Binding Settings.ShowOverlayInGame}"
                                                      Foreground="{StaticResource TextSecondaryBrush}"
                                                      Content="Afficher l'overlay en jeu"
                                                      FontSize="13"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="Opacité :"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <Slider Minimum="0.3" Maximum="1.0"
                                                    Value="{Binding Settings.OverlayOpacity}"
                                                    Width="200" VerticalAlignment="Center"/>
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <Run Text="{Binding Settings.OverlayOpacity, StringFormat={}{0:P0}, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                         <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                             <TextBlock Text="Échelle :"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                             <Slider Minimum="0.85" Maximum="1.30" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                                     Value="{Binding Settings.UiScale, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="200" VerticalAlignment="Center"/>
                                             <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                        FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                                                        Text="{Binding Settings.UiScale, StringFormat={}{0:P0}}"/>
                                         </StackPanel>
                                         <TextBlock Text="Les changements sont appliqués dès la sauvegarde."
                                                    Style="{StaticResource SubtleCaption}" TextWrapping="Wrap"/>
                                         <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                             <TextBlock Text="Raccourci :"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                             <TextBox Width="100" MaxLength="6"
                                                      Text="{Binding Settings.OverlayHotkey, UpdateSourceTrigger=PropertyChanged}"
                                                      ToolTip="Format accepté : Ctrl suivi d’une lettre, par exemple Ctrl+X"
                                                      AutomationProperties.Name="Raccourci de l’overlay"/>
                                             <TextBlock Text="Utilisez Ctrl + une lettre (ex. Ctrl+X)."
                                                        Style="{StaticResource SubtleCaption}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                         </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Save button -->
                                <Button Content="Sauvegarder les paramètres"
                                        Style="{StaticResource AccentButton}"
                                        Command="{Binding SaveSettingsCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="16,10" FontSize="14"/>

                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" Margin="0,10,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- COMING SOON PAGE -->
                    <Grid x:Name="PageComingSoon" Visibility="Collapsed">
                        <Border Background="{StaticResource GlassCardBrush}"
                                BorderBrush="{StaticResource SoftBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="34">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock x:Name="ComingSoonTitle"
                                               Text="Module bientôt disponible"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="28"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Cette section est prévue dans l’interface du launcher, mais elle n’est pas encore activée."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="14"
                                               Margin="0,6,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="520">
                                    <Border Width="86" Height="86" CornerRadius="24" HorizontalAlignment="Center"
                                            Background="#182B52" BorderBrush="#38588E" BorderThickness="1">
                                        <TextBlock Text="✦" Foreground="{StaticResource AccentBlueLightBrush}"
                                                   FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Bientôt disponible"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Margin="0,18,0,0"/>
                                    <TextBlock x:Name="ComingSoonDescription"
                                               Text="Je garde l’emplacement visuel pour rester fidèle à la maquette, sans ajouter de fausse fonctionnalité."
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="14"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>
                                    <Button Content="Retour Mon Compte"
                                            Style="{StaticResource HeaderActionButton}"
                                            Click="BackToMyAccountButton_Click"
                                            HorizontalAlignment="Center"
                                            Margin="0,24,0,0"
                                            Padding="18,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ══════════════════════════════════════════════════════════ -->
                    <!--  PANNEAU DÉTAIL DE PARTIE — superposé par-dessus tout     -->
                    <!--  Visible uniquement quand SelectedMatch != null            -->
                    <!-- ══════════════════════════════════════════════════════════ -->
                    <Grid x:Name="MatchDetailPanel"
                          Visibility="Collapsed"
                          Panel.ZIndex="100">

                        <!-- Fond semi-transparent -->
                        <Rectangle Fill="#CC151B24"/>

                        <!-- Carte centrale -->
                        <Border Background="{StaticResource BgPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="20,16"
                                DataContext="{Binding SelectedMatch}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="46"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- ── Header ── -->
                                <Border Grid.Row="0"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="10,10,0,0"
                                        Padding="16,0"
                                        Background="{StaticResource BgSecondaryBrush}">
                                    <Grid>
                                        <!-- Infos partie — masquées pendant le chargement -->
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,40,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Border Background="{StaticResource BgCardBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1" CornerRadius="4"
                                                    Padding="8,3" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding QueueName}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Margin="0,0,8,0">
                                                <Run Text="{Binding GameDuration, Converter={StaticResource GameDuration}}"/>
                                            </TextBlock>
                                            <TextBlock Text="·" Foreground="{StaticResource BorderBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12" VerticalAlignment="Center">
                                                <Run Text="{Binding GameCreation, Converter={StaticResource TimeAgo}}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Bouton fermer -->
                                        <Button HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Click="CloseMatchDetailPanel_Click"
                                                Width="28" Height="28"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="✕"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- ── Loading ── -->
                                <Grid Grid.Row="1"
                                      Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="⏳" FontSize="36" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Chargement de la partie..."
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="14" HorizontalAlignment="Center"
                                                   Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ── Contenu (équipes côte à côte) ── -->
                                <Grid Grid.Row="1"
                                      Visibility="{Binding IsLoading, Converter={StaticResource InvBoolVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- VICTOIRE -->
                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="34"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Background="#0A2010"
                                                BorderBrush="#238636"
                                                BorderThickness="0,0,0,2"
                                                Padding="14,0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🏆 " FontSize="13"/>
                                                <TextBlock Text="VICTOIRE"
                                                           Foreground="#3FB950"
                                                           FontWeight="Bold" FontSize="13"/>
                                            </StackPanel>
                                        </Border>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Style="{StaticResource SlimScrollViewer}">
                                            <ItemsControl ItemsSource="{Binding BlueTeam}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,7"
                                                                Cursor="Hand"
                                                                MouseLeftButtonUp="MatchParticipant_Click">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="34"/>  <!-- Champion icon -->
                                                                    <ColumnDefinition Width="22"/>  <!-- Sorts -->
                                                                    <ColumnDefinition Width="*"/>   <!-- Nom -->
                                                                    <ColumnDefinition Width="76"/>  <!-- KDA -->
                                                                    <ColumnDefinition Width="44"/>  <!-- CS -->
                                                                    <ColumnDefinition Width="46"/>  <!-- Champ name -->
                                                                    <ColumnDefinition Width="44"/>  <!-- Score perf -->
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Icône champion -->
                                                                <Border Grid.Column="0" Width="30" Height="30"
                                                                        CornerRadius="4" ClipToBounds="True"
                                                                        VerticalAlignment="Center">
                                                                    <Image Source="{Binding ChampionName, Converter={StaticResource ChampImg}}"/>
                                                                </Border>

                                                                <!-- Sorts invocateur -->
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0">
                                                                    <Border Width="16" Height="16" CornerRadius="2" ClipToBounds="True" Margin="0,0,0,1">
                                                                        <Image Source="{Binding Summoner1Id, Converter={StaticResource SpellImg}}"/>
                                                                    </Border>
                                                                    <Border Width="16" Height="16" CornerRadius="2" ClipToBounds="True">
                                                                        <Image Source="{Binding Summoner2Id, Converter={StaticResource SpellImg}}"/>
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- Nom + position -->
                                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontSize="12" FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding Position}"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               FontSize="10"/>
                                                                </StackPanel>

                                                                <!-- KDA -->
                                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                    <TextBlock HorizontalAlignment="Center" FontSize="12">
                                                                        <Run Text="{Binding Kills}"   Foreground="#3FB950"/>
                                                                        <Run Text=" / " Foreground="{StaticResource TextMutedBrush}"/>
                                                                        <Run Text="{Binding Deaths}"  Foreground="#F85149"/>
                                                                        <Run Text=" / " Foreground="{StaticResource TextMutedBrush}"/>
                                                                        <Run Text="{Binding Assists}" Foreground="#58A6FF"/>
                                                                    </TextBlock>
                                                                    <TextBlock HorizontalAlignment="Center"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               FontSize="10">
                                                                        <Run Text="{Binding KDA, Converter={StaticResource DoubleFmt}, Mode=OneWay}"/>
                                                                        <Run Text=" KDA"/>
                                                                    </TextBlock>
                                                                </StackPanel>

                                                                <!-- CS -->
                                                                <TextBlock Grid.Column="4"
                                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11">
                                                                    <Run Text="{Binding CS}"/>
                                                                    <Run Text=" CS"/>
                                                                </TextBlock>

                                                                <!-- Champion name -->
                                                                <TextBlock Grid.Column="5"
                                                                           Text="{Binding ChampionName}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="10" VerticalAlignment="Center"
                                                                           HorizontalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"/>

                                                                <!-- Score de performance — BlueTeam -->
                                                                <Grid Grid.Column="6" Width="38" Height="38"
                                                                      VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                    <Ellipse StrokeThickness="2.5" Fill="Transparent">
                                                                        <Ellipse.Style>
                                                                            <Style TargetType="Ellipse">
                                                                                <Setter Property="Stroke" Value="#3B82F6"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding PerformanceScore}" Value="100">
                                                                                        <Setter Property="Stroke" Value="#F5A623"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding PerformanceScore}" Value="99">
                                                                                        <Setter Property="Stroke" Value="#10B981"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Ellipse.Style>
                                                                    </Ellipse>
                                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                        <TextBlock FontSize="10" FontWeight="Bold" HorizontalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#C9D1D9"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding PerformanceScore}" Value="100">
                                                                                            <Setter Property="Foreground" Value="#F5A623"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding PerformanceScore}" Value="99">
                                                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                            <Run Text="{Binding PerformanceScore, Mode=OneWay}"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontSize="7" FontWeight="Bold" HorizontalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value=""/>
                                                                                    <Setter Property="Foreground" Value="#6B7280"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding PerformanceScore}" Value="100">
                                                                                            <Setter Property="Text" Value="MVP"/>
                                                                                            <Setter Property="Foreground" Value="#F5A623"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding PerformanceScore}" Value="99">
                                                                                            <Setter Property="Text" Value="ACE"/>
                                                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>

                                    <!-- Séparateur VS -->
                                    <TextBlock Grid.Column="1"
                                               Text="VS"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontWeight="Bold" FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <!-- DÉFAITE -->
                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="34"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Background="#200A0A"
                                                BorderBrush="#F85149"
                                                BorderThickness="0,0,0,2"
                                                Padding="14,0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="💀 " FontSize="13"/>
                                                <TextBlock Text="DÉFAITE"
                                                           Foreground="#F85149"
                                                           FontWeight="Bold" FontSize="13"/>
                                            </StackPanel>
                                        </Border>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Style="{StaticResource SlimScrollViewer}">
                                            <ItemsControl ItemsSource="{Binding RedTeam}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,7"
                                                                Cursor="Hand"
                                                                MouseLeftButtonUp="MatchParticipant_Click">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <!-- Côté ennemi : layout miroir (champ name | CS | KDA | nom | sorts | icône) -->
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="46"/>  <!-- Champ name -->
                                                                    <ColumnDefinition Width="44"/>  <!-- CS -->
                                                                    <ColumnDefinition Width="76"/>  <!-- KDA -->
                                                                    <ColumnDefinition Width="*"/>   <!-- Nom -->
                                                                    <ColumnDefinition Width="22"/>  <!-- Sorts -->
                                                                    <ColumnDefinition Width="34"/>  <!-- Champion icon -->
                                                                    <ColumnDefinition Width="44"/>  <!-- Score perf -->
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Champion name -->
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding ChampionName}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="10" VerticalAlignment="Center"
                                                                           HorizontalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"/>

                                                                <!-- CS -->
                                                                <TextBlock Grid.Column="1"
                                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11">
                                                                    <Run Text="{Binding CS}"/>
                                                                    <Run Text=" CS"/>
                                                                </TextBlock>

                                                                <!-- KDA -->
                                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                    <TextBlock HorizontalAlignment="Center" FontSize="12">
                                                                        <Run Text="{Binding Kills}"   Foreground="#3FB950"/>
                                                                        <Run Text=" / " Foreground="{StaticResource TextMutedBrush}"/>
                                                                        <Run Text="{Binding Deaths}"  Foreground="#F85149"/>
                                                                        <Run Text=" / " Foreground="{StaticResource TextMutedBrush}"/>
                                                                        <Run Text="{Binding Assists}" Foreground="#58A6FF"/>
                                                                    </TextBlock>
                                                                    <TextBlock HorizontalAlignment="Center"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               FontSize="10">
                                                                        <Run Text="{Binding KDA, Converter={StaticResource DoubleFmt}, Mode=OneWay}"/>
                                                                        <Run Text=" KDA"/>
                                                                    </TextBlock>
                                                                </StackPanel>

                                                                <!-- Nom + position -->
                                                                <StackPanel Grid.Column="3" VerticalAlignment="Center"
                                                                            HorizontalAlignment="Right" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontSize="12" FontWeight="SemiBold"
                                                                               TextAlignment="Right"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding Position}"
                                                                               Foreground="{StaticResource TextMutedBrush}"
                                                                               FontSize="10" TextAlignment="Right"/>
                                                                </StackPanel>

                                                                <!-- Sorts invocateur -->
                                                                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="2,0">
                                                                    <Border Width="16" Height="16" CornerRadius="2" ClipToBounds="True" Margin="0,0,0,1">
                                                                        <Image Source="{Binding Summoner1Id, Converter={StaticResource SpellImg}}"/>
                                                                    </Border>
                                                                    <Border Width="16" Height="16" CornerRadius="2" ClipToBounds="True">
                                                                        <Image Source="{Binding Summoner2Id, Converter={StaticResource SpellImg}}"/>
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- Icône champion -->
                                                                <Border Grid.Column="5" Width="30" Height="30"
                                                                        CornerRadius="4" ClipToBounds="True"
                                                                        VerticalAlignment="Center">
                                                                    <Image Source="{Binding ChampionName, Converter={StaticResource ChampImg}}"/>
                                                                </Border>

                                                                <!-- Score de performance — RedTeam -->
                                                                <Grid Grid.Column="6" Width="38" Height="38"
                                                                      VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                    <Ellipse StrokeThickness="2.5" Fill="Transparent">
                                                                        <Ellipse.Style>
                                                                            <Style TargetType="Ellipse">
                                                                                <Setter Property="Stroke" Value="#3B82F6"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding PerformanceScore}" Value="100">
                                                                                        <Setter Property="Stroke" Value="#F5A623"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding PerformanceScore}" Value="99">
                                                                                        <Setter Property="Stroke" Value="#10B981"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Ellipse.Style>
                                                                    </Ellipse>
                                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                        <TextBlock FontSize="10" FontWeight="Bold" HorizontalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#C9D1D9"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding PerformanceScore}" Value="100">
                                                                                            <Setter Property="Foreground" Value="#F5A623"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding PerformanceScore}" Value="99">
                                                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                            <Run Text="{Binding PerformanceScore, Mode=OneWay}"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontSize="7" FontWeight="Bold" HorizontalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value=""/>
                                                                                    <Setter Property="Foreground" Value="#6B7280"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding PerformanceScore}" Value="100">
                                                                                            <Setter Property="Text" Value="MVP"/>
                                                                                            <Setter Property="Foreground" Value="#F5A623"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding PerformanceScore}" Value="99">
                                                                                            <Setter Property="Text" Value="ACE"/>
                                                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                    <!-- ══════════════════════════════════════════════════════════ -->
                    <!--  PANNEAU LIVE GAME — partie en cours d'un joueur recherché -->
                    <!-- ══════════════════════════════════════════════════════════ -->
                    <Grid Visibility="{Binding HasLiveGameDetail, Converter={StaticResource BoolVis}}"
                          Panel.ZIndex="101">

                        <!-- Fond semi-transparent -->
                        <Rectangle Fill="#CC151B24"/>

                        <!-- Carte centrale -->
                        <Border Background="{StaticResource BgPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Margin="20,16"
                                DataContext="{Binding LiveGameDetail}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="46"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Grid.Row="0"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="10,10,0,0"
                                        Padding="16,0"
                                        Background="{StaticResource BgSecondaryBrush}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Fill="#FF6B3D" Margin="0,0,8,0"/>
                                            <TextBlock Text="PARTIE EN COURS"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Command="{Binding DataContext.CloseLiveGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Width="28" Height="28"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="✕" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Corps : Alliés | Ennemis -->
                                <Grid Grid.Row="1">

                                    <!-- Chargement -->
                                    <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                        <TextBlock Text="⏳ Chargement des joueurs..."
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="13" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource InvBoolVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Alliés -->
                                        <Grid Grid.Column="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="32"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Padding="12,0"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <TextBlock Text="ALLIÉS"
                                                           Foreground="#3B82F6"
                                                           FontSize="11" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ScrollViewer Grid.Row="1"
                                                          VerticalScrollBarVisibility="Auto"
                                                          Style="{StaticResource SlimScrollViewer}">
                                                <ItemsControl ItemsSource="{Binding AllyTeam}" Margin="8">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <views:LivePlayerCard DataContext="{Binding}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>

                                        <!-- Séparateur -->
                                        <Rectangle Grid.Column="1"
                                                   Fill="{StaticResource BorderBrush}"/>

                                        <!-- Ennemis -->
                                        <Grid Grid.Column="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="32"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Padding="12,0"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <TextBlock Text="ENNEMIS"
                                                           Foreground="#EF4444"
                                                           FontSize="11" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ScrollViewer Grid.Row="1"
                                                          VerticalScrollBarVisibility="Auto"
                                                          Style="{StaticResource SlimScrollViewer}">
                                                <ItemsControl ItemsSource="{Binding EnemyTeam}" Margin="8">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <views:LivePlayerCard DataContext="{Binding}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                    <!-- FIN PANNEAU LIVE GAME -->

                    <!-- ══════════════════════════════════════════════════════════ -->
                    <!--  PANNEAU RÉCAP FIN DE PARTIE — maquette équipe / objectifs -->
                    <!-- ══════════════════════════════════════════════════════════ -->
                    <Grid Visibility="{Binding HasSelectedMatch, Converter={StaticResource BoolVis}}"
                          Panel.ZIndex="120">
                        <Rectangle Fill="#DD080D18"/>

                        <Border Margin="18,12"
                                Background="#11182A"
                                BorderBrush="#31415D"
                                BorderThickness="1"
                                CornerRadius="13"
                                DataContext="{Binding SelectedMatch}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="6" Opacity="0.55"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="52"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Barre d'informations -->
                                <Border Grid.Row="0" Background="#17233B" CornerRadius="13,13,0,0"
                                        BorderBrush="#31415D" BorderThickness="0,0,0,1" Padding="14,0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Background="#26344F" BorderBrush="#3A4A69" BorderThickness="1"
                                                    CornerRadius="7" Padding="10,4">
                                                <TextBlock Text="{Binding QueueName}" Foreground="#E6EDF3" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text="{Binding GameDuration, Converter={StaticResource GameDuration}}"
                                                       Foreground="#A7B0BC" FontSize="12" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text=" • " Foreground="#61708C" Margin="8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding GameCreation, Converter={StaticResource TimeAgo}}"
                                                       Foreground="#A7B0BC" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Command="{Binding DataContext.CloseMatchDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Style="{StaticResource IconButton}" Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource TextSecondaryBrush}" ToolTip="Fermer">
                                                <TextBlock Text="✕" FontSize="14"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource SlimScrollViewer}">
                                    <StackPanel Margin="12,10,12,14">
                                        <!-- Score et deux équipes -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Équipe gagnante -->
                                            <Border Grid.Column="0" CornerRadius="12,35,35,12" Padding="12,10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#163642" Offset="0"/>
                                                        <GradientStop Color="#111C30" Offset="0.85"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="3,0,0,7">
                                                        <TextBlock Text="⚔" Foreground="#3FB950" FontSize="17" Margin="0,0,9,0"/>
                                                        <TextBlock Text="VICTOIRE" Foreground="#3FB950" FontSize="17" FontWeight="Bold"/>
                                                    </StackPanel>
                                                    <Border Height="1" Background="#285061" Margin="0,0,0,3"/>
                                                    <ItemsControl ItemsSource="{Binding WinningTeam}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Height="73" Margin="0,1">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="52"/>
                                                                        <RowDefinition Height="21"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="43"/>
                                                                        <ColumnDefinition Width="24"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="76"/>
                                                                        <ColumnDefinition Width="80"/>
                                                                        <ColumnDefinition Width="38"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="39" Height="39" CornerRadius="5" VerticalAlignment="Center" ClipToBounds="True">
                                                                        <Image Source="{Binding ChampionName, Converter={StaticResource ChampImg}}" Stretch="UniformToFill"/>
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                                                        <Image Width="18" Height="18" Margin="0,0,0,2" Source="{Binding Summoner1Id, Converter={StaticResource SpellImg}}"/>
                                                                        <Image Width="18" Height="18" Source="{Binding Summoner2Id, Converter={StaticResource SpellImg}}"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="3,0,4,0">
                                                                        <TextBlock Text="{Binding DisplayName}" Foreground="#EDF3FA" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding Position}" Foreground="#8291AA" FontSize="9" Margin="0,2,0,0"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                        <TextBlock FontSize="11" HorizontalAlignment="Center">
                                                                            <Run Text="{Binding Kills}" Foreground="#3FB950"/><Run Text=" / " Foreground="#718099"/><Run Text="{Binding Deaths}" Foreground="#F85169"/><Run Text=" / " Foreground="#718099"/><Run Text="{Binding Assists}" Foreground="#55A4FF"/>
                                                                        </TextBlock>
                                                                        <TextBlock Text="{Binding KDA, StringFormat={}{0:F2} KDA}" Foreground="#93A1B8" FontSize="9" HorizontalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding CS, StringFormat={}{0} CS}" Foreground="#CFD9E8" FontSize="11" HorizontalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding CSPerMinDisplay}" Foreground="#8291AA" FontSize="9" HorizontalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <Grid Grid.Column="5" Width="33" Height="33" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                                        <Ellipse Stroke="#3B82F6" StrokeThickness="1.5"/>
                                                                        <TextBlock Text="{Binding PerformanceScore}" Foreground="#E6EDF3" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                    </Grid>
                                                                    <!-- Build final du joueur -->
                                                                    <ItemsControl Grid.Row="1" Grid.ColumnSpan="6"
                                                                                  ItemsSource="{Binding BuildItems}"
                                                                                  HorizontalAlignment="Left"
                                                                                  Margin="1,0,0,1">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Width="18" Height="18" CornerRadius="3" ClipToBounds="True"
                                                                                        Background="#0B1220" BorderBrush="#36506B" BorderThickness="1" Margin="0,0,3,0">
                                                                                    <Image Source="{Binding Converter={StaticResource ItemToImg}}" Stretch="UniformToFill"/>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Score central -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,12,0,0">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding WinningTeamKills}" Foreground="#3FB950" FontSize="31" FontWeight="Bold"/>
                                                    <TextBlock Text="VS" Foreground="#8D9BB0" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="18,0"/>
                                                    <TextBlock Text="{Binding LosingTeamKills}" Foreground="#F85169" FontSize="31" FontWeight="Bold"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,19,0,0">
                                                    <TextBlock Text="{Binding WinningTeamGold, StringFormat={}{0:N0}}" Foreground="#3FB950" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="  GOLD  " Foreground="#8D9BB0" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding LosingTeamGold, StringFormat={}{0:N0}}" Foreground="#F85169" FontSize="13" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                                                    <TextBlock Text="{Binding WinningTowers}" Foreground="#3FB950" FontSize="13" FontWeight="Bold"/>
                                                    <TextBlock Text="  TOURS  " Foreground="#8D9BB0" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding LosingTowers}" Foreground="#F85169" FontSize="13" FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Équipe perdante -->
                                            <Border Grid.Column="2" CornerRadius="35,12,12,35" Padding="12,10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                                                        <GradientStop Color="#42203B" Offset="0"/>
                                                        <GradientStop Color="#161B30" Offset="0.86"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,3,7">
                                                        <TextBlock Text="DÉFAITE" Foreground="#F85169" FontSize="17" FontWeight="Bold"/>
                                                        <TextBlock Text=" ⚔" Foreground="#F85169" FontSize="17" Margin="9,0,0,0"/>
                                                    </StackPanel>
                                                    <Border Height="1" Background="#5A2D4D" Margin="0,0,0,3"/>
                                                    <ItemsControl ItemsSource="{Binding LosingTeam}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Height="73" Margin="0,1">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="52"/>
                                                                        <RowDefinition Height="21"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="38"/>
                                                                        <ColumnDefinition Width="80"/>
                                                                        <ColumnDefinition Width="76"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="24"/>
                                                                        <ColumnDefinition Width="43"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid Grid.Column="0" Width="33" Height="33" VerticalAlignment="Center">
                                                                        <Ellipse Stroke="#4E93F0" StrokeThickness="1.5"/>
                                                                        <TextBlock Text="{Binding PerformanceScore}" Foreground="#E6EDF3" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                    </Grid>
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding CS, StringFormat={}{0} CS}" Foreground="#CFD9E8" FontSize="11" HorizontalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding CSPerMinDisplay}" Foreground="#8291AA" FontSize="9" HorizontalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                        <TextBlock FontSize="11" HorizontalAlignment="Center">
                                                                            <Run Text="{Binding Kills}" Foreground="#3FB950"/><Run Text=" / " Foreground="#718099"/><Run Text="{Binding Deaths}" Foreground="#F85169"/><Run Text=" / " Foreground="#718099"/><Run Text="{Binding Assists}" Foreground="#55A4FF"/>
                                                                        </TextBlock>
                                                                        <TextBlock Text="{Binding KDA, StringFormat={}{0:F2} KDA}" Foreground="#93A1B8" FontSize="9" HorizontalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,3,0">
                                                                        <TextBlock Text="{Binding DisplayName}" Foreground="#EDF3FA" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"/>
                                                                        <TextBlock Text="{Binding Position}" Foreground="#8291AA" FontSize="9" Margin="0,2,0,0" HorizontalAlignment="Right"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0,0,4,0">
                                                                        <Image Width="18" Height="18" Margin="0,0,0,2" Source="{Binding Summoner1Id, Converter={StaticResource SpellImg}}"/>
                                                                        <Image Width="18" Height="18" Source="{Binding Summoner2Id, Converter={StaticResource SpellImg}}"/>
                                                                    </StackPanel>
                                                                    <Border Grid.Column="5" Width="39" Height="39" CornerRadius="5" VerticalAlignment="Center" HorizontalAlignment="Right" ClipToBounds="True">
                                                                        <Image Source="{Binding ChampionName, Converter={StaticResource ChampImg}}" Stretch="UniformToFill"/>
                                                                    </Border>
                                                                    <!-- Build final du joueur -->
                                                                    <ItemsControl Grid.Row="1" Grid.ColumnSpan="6"
                                                                                  ItemsSource="{Binding BuildItems}"
                                                                                  HorizontalAlignment="Right"
                                                                                  Margin="0,0,1,1">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Width="18" Height="18" CornerRadius="3" ClipToBounds="True"
                                                                                        Background="#200F1B" BorderBrush="#6A3A57" BorderThickness="1" Margin="3,0,0,0">
                                                                                    <Image Source="{Binding Converter={StaticResource ItemToImg}}" Stretch="UniformToFill"/>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Cartes de synthèse : le bloc Résumés des équipes est volontairement absent -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.35*"/>
                                                <ColumnDefinition Width="0.78*"/>
                                                <ColumnDefinition Width="1.1*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Style="{StaticResource CompactCardStyle}" Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Text="DÉGÂTS TOTAUX" Style="{StaticResource SectionLabel}"/>
                                                    <Grid Margin="0,13,0,8">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding WinningTeamDamage, StringFormat={}{0:N0}}" Foreground="#3FB950" FontWeight="Bold" FontSize="14"/>
                                                            <TextBlock Text="{Binding WinningDamagePercentDisplay}" Foreground="#77C98A" FontSize="10" VerticalAlignment="Bottom" Margin="5,0,0,1"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding LosingDamagePercentDisplay}" Foreground="#F28A9A" FontSize="10" VerticalAlignment="Bottom" Margin="0,0,5,1"/>
                                                            <TextBlock Text="{Binding LosingTeamDamage, StringFormat={}{0:N0}}" Foreground="#F85169" FontWeight="Bold" FontSize="14"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Border Height="8" CornerRadius="4" ClipToBounds="True" Background="#F85169">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding WinningDamagePercent, Converter={StaticResource PercentToGridLength}}"/>
                                                                <ColumnDefinition Width="{Binding LosingDamagePercent, Converter={StaticResource PercentToGridLength}}"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Background="#3FB950"/>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Style="{StaticResource CompactCardStyle}" Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Text="OBJECTIFS" Style="{StaticResource SectionLabel}"/>
                                                    <Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding WinningDragons}" Foreground="#3FB950" FontWeight="Bold" HorizontalAlignment="Right"/><TextBlock Grid.Column="1" Text="  DRAGONS  " Foreground="#A7B0BC" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding LosingDragons}" Foreground="#F85169" FontWeight="Bold"/>
                                                    </Grid>
                                                    <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding WinningBarons}" Foreground="#3FB950" FontWeight="Bold" HorizontalAlignment="Right"/><TextBlock Grid.Column="1" Text="  BARONS  " Foreground="#A7B0BC" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding LosingBarons}" Foreground="#F85169" FontWeight="Bold"/>
                                                    </Grid>
                                                    <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding WinningTowers}" Foreground="#3FB950" FontWeight="Bold" HorizontalAlignment="Right"/><TextBlock Grid.Column="1" Text="  TOURS  " Foreground="#A7B0BC" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding LosingTowers}" Foreground="#F85169" FontWeight="Bold"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}" Margin="0,0,8,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="MVP DE LA PARTIE" Style="{StaticResource SectionLabel}"/>
                                                        <TextBlock Text="{Binding MvpPlayer.DisplayName}" Foreground="#E6EDF3" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding MvpPlayer.KdaLine}" Foreground="#A7B0BC" FontSize="11"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="0" Width="51" Height="51" CornerRadius="6" VerticalAlignment="Center" ClipToBounds="True">
                                                        <Image Source="{Binding MvpPlayer.ChampionName, Converter={StaticResource ChampImg}}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <Grid Grid.Column="2" Width="36" Height="36" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                        <Ellipse Stroke="#F0C040" StrokeThickness="2"/><TextBlock Text="{Binding MvpPlayer.PerformanceScore}" Foreground="#F0C040" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Column="3" Style="{StaticResource CompactCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="BANS" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <ItemsControl ItemsSource="{Binding WinningBans}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate><DataTemplate><Border Width="27" Height="27" Margin="0,0,3,0" CornerRadius="3" Opacity="0.58" ClipToBounds="True"><Image Source="{Binding Converter={StaticResource ChampIdImg}}" Stretch="UniformToFill"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Border Width="1" Height="27" Background="#43506A" Margin="3,0"/>
                                                        <ItemsControl ItemsSource="{Binding LosingBans}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate><DataTemplate><Border Width="27" Height="27" Margin="3,0,0,0" CornerRadius="3" Opacity="0.58" ClipToBounds="True"><Image Source="{Binding Converter={StaticResource ChampIdImg}}" Stretch="UniformToFill"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                    <!-- FIN PANNEAU RÉCAP FIN DE PARTIE -->
                </Grid>
            </Grid>

            <!-- ══════════════════════════════════════════════════════ -->
            <!--  STATUS BAR                                            -->
            <!-- ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Background="{StaticResource BgPrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                <Grid Margin="12,0">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="MixOverlays v1.0 • by Mix"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
