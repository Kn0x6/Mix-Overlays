<UserControl x:Class="MixOverlays.Views.WinRateGaugeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="150" Height="128"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid>
        <!-- Les arcs sont créés en code afin de suivre exactement le WinRate. -->
        <Canvas x:Name="GaugeCanvas"
                Height="82"
                Margin="7,0,7,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                SizeChanged="GaugeCanvas_SizeChanged"/>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,29,0,0">
            <TextBlock Text="{Binding WinRate, ElementName=Root, StringFormat={}{0:F0}%}"
                       Foreground="#7AA2FF"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Winrate"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,1,0,0"/>
        </StackPanel>

        <TextBlock VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,6"
                   FontSize="15"
                   FontWeight="SemiBold">
            <Run Text="{Binding Wins, ElementName=Root}" Foreground="#4A90FF"/>
            <Run Text="W" Foreground="#4A90FF"/>
            <Run Text=" - " Foreground="{StaticResource TextMutedBrush}"/>
            <Run Text="{Binding Losses, ElementName=Root}" Foreground="#F04B86"/>
            <Run Text="L" Foreground="#F04B86"/>
        </TextBlock>
    </Grid>
</UserControl>